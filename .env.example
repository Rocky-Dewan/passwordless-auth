# ─── Application ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=auth_user
DB_PASSWORD=auth_password
DB_NAME=passwordless_auth_db

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT  (change in production — use 64+ random chars) ────────────
JWT_SECRET=change_me_to_64_random_chars_for_production_xxxxxxxxxxxxxxxxxx
JWT_EXPIRY=7d

# ─── CSRF (change in production) ───────────────────────────────────
CSRF_SECRET=change_me_to_another_64_random_chars_xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email via Brevo (free 300 emails/day) ─────────────────────────
# 1. Sign up at https://www.brevo.com
# 2. Settings → SMTP & API → SMTP tab
# 3. Copy your SMTP login and generate an SMTP key (password)
# 4. Paste below — EMAIL_USER is your Brevo login email
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=rocky250.dewan@gmail.com
EMAIL_PASS=your_brevo_smtp_key_here
EMAIL_FROM=rocky250.dewan@gmail.com

# ─── Auth settings ─────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=250
MAGIC_LINK_EXPIRY_SECONDS=250
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
