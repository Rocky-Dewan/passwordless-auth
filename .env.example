# Application
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=auth_user
DB_PASSWORD=auth_password
DB_NAME=passwordless_auth_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_minimum_64_chars_for_production
JWT_EXPIRY=7d

# CSRF
CSRF_SECRET=change_this_to_another_long_random_secret_for_csrf_protection

# -----------------------------------------------------------------------
# Email via Brevo (free 300 emails/day)
# 1. Sign up at https://www.brevo.com
# 2. Go to SMTP & API -> SMTP tab
# 3. Copy your login and master password or create an SMTP key
# -----------------------------------------------------------------------
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@yourapp.com

# OTP / Magic Link
OTP_EXPIRY_SECONDS=250
MAGIC_LINK_EXPIRY_SECONDS=250
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
